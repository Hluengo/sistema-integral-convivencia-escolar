{
  "name": "sistema-integral-convivencia-escolar",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "build:web": "vite build",
    "start": "node dist/server.cjs",
    "clean": "rimraf dist server.js",
    "lint": "tsc --noEmit",
    "test": "tsx --test src/domain/disciplinaryStatus.test.ts src/domain/riceMeasures.test.ts src/lib/mappers.test.ts",
    "ci": "npm run lint && npm run test && npm run build:web",
    "doctor": "npx react-doctor@latest"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@supabase/supabase-js": "^2.110.3",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "docx": "^9.7.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "pdf-lib": "^1.17.1",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-router-dom": "^7.18.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react-router-dom": "^5.3.3",
    "@vercel/node": "^5.8.25",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "react-doctor": "^0.7.8",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
