    "test": "tsx --test src/domain/disciplinaryStatus.test.ts src/domain/riceMeasures.test.ts src/lib/mappers.test.ts",
    "ci": "npm run lint && npm run test && npm run build:web",
    "doctor": "npx react-doctor@latest"
  },
