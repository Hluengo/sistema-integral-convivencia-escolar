{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server/index.ts",
    "build": "vite build && esbuild server/index.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs && npm run build:api",
    "build:api": "esbuild server/api/index.ts --bundle --platform=node --format=esm --packages=external --outfile=api/index.js",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "biome lint --write .",
    "format": "biome format --write .",
    "lint:check": "biome lint .",
    "format:check": "biome format .",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test \"src/**/*.test.ts\"",
    "test:e2e": "tsx --test \"e2e/**/*.test.ts\"",
    "doctor": "npx react-doctor@latest",
    "build:web": "vite build",
    "ci": "npm run typecheck && npm run test && npm run build:web",
    "analyze": "cross-env ANALYZE=true npm run build"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.19",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-popover": "^1.1.19",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.17",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@sentry/browser": "^10.66.0",
    "@sentry/react": "^10.66.0",
    "@supabase/supabase-js": "^2.108.2",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/react-query": "^5.101.2",
    "@vitejs/plugin-react": "^5.0.4",
    "compression": "^1.8.1",
    "docx": "^9.7.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "file-saver": "^2.0.5",
    "lucide-react": "^0.546.0",
    "pdf-lib": "^1.17.1",
    "posthog-js": "^1.403.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "scheduler": "^0.27.0",
    "web-vitals": "^5.3.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@supabase/mcp-server-supabase": "^0.8.2",
    "@tailwindcss/language-server": "^0.14.29",
    "@types/compression": "^1.8.1",
    "@types/express": "^4.17.21",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "cross-env": "^10.1.0",
    "esbuild": "^0.25.0",
    "playwright": "^1.61.1",
    "react-doctor": "^0.7.2",
    "rimraf": "^6.1.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "typescript-language-server": "^5.3.0",
    "vite": "^6.2.3",
    "vite-bundle-analyzer": "^1.3.9",
    "vscode-langservers-extracted": "^4.10.0"
  }
}
