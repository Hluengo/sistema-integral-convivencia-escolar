{
  "name": "sistema-integral-convivencia-escolar",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server/index.ts",
    "build": "vite build && esbuild server/index.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs && esbuild server/api/index.ts --bundle --platform=node --format=esm --packages=external --outfile=api/index.js",
    "build:web": "vite build",
    "start": "node dist/server.cjs",
    "clean": "rimraf dist server.js",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/domain/disciplinaryStatus.test.ts src/domain/riceMeasures.test.ts src/lib/mappers.test.ts server/lib/disciplinaryPdfAnalysis.test.ts server/lib/validators.test.ts",
    "ci": "npm run lint && npm run test && npm run build:web",
    "doctor": "npx react-doctor@latest",
    "prepare": "husky",
    "lint:types": "tsc --noEmit",
    "lint:code": "eslint .",
    "lint:code:fix": "eslint . --fix",
    "lint-staged": "lint-staged",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run lint && npm run lint:code && npm run test && npm run build:web"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.19",
    "@radix-ui/react-dialog": "^1.1.19",
    "@sentry/browser": "^10.66.0",
    "@sentry/react": "^10.66.0",
    "@supabase/supabase-js": "^2.110.3",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-table": "^8.21.3",
    "compression": "^1.8.1",
    "date-fns": "^4.4.0",
    "docx": "^9.7.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "file-saver": "^2.0.5",
    "lucide-react": "^0.546.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^6.1.200",
    "posthog-js": "^1.404.1",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-hook-form": "^7.82.0",
    "web-vitals": "^5.3.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^9.39.5",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/compression": "^1.8.1",
    "@types/express": "^4.17.21",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vercel/node": "^5.8.25",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/coverage-v8": "^4.1.10",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.1.1",
    "prettier": "^3.9.6",
    "react-doctor": "^0.7.8",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.65.0",
    "vite": "^6.2.3",
    "vitest": "^4.1.10"
  }
}
