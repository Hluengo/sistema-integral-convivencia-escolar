# === Servidor ===
PORT=3001
APP_URL=http://localhost:3000
NODE_ENV=development

# === CORS ===
# Orígenes permitidos separados por coma. Vacío = sin CORS (solo same-origin).
# Ejemplo: https://app.ejemplo.cl,https://otra-app.vercel.app
ALLOWED_ORIGINS=

# === OpenRouter API (servidor / Vercel) ===
# Modelo usado: meta-llama/llama-3.1-8b-instruct
OPENROUTER_API_KEY=your_openrouter_api_key

# === Supabase ===
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# JWT secret para verificación de tokens en API routes (server/index.ts / api/index.js)
# Se obtiene en Supabase Dashboard > Settings > API > JWT Settings
SUPABASE_JWT_SECRET=your_supabase_jwt_secret

# Service role key (solo para operaciones privilegiadas desde servidor)
# NO exponer en frontend. Se obtiene en Supabase Dashboard > Settings > API
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
DEFAULT_TENANT_ID=your_default_tenant_uuid

# Demo local sin login (solo desarrollo). En producción dejar en false o omitir.
VITE_ALLOW_LOCAL_DEMO=false

# === Sentry (Error Tracking) ===
# Obtener en https://sentry.io/settings/projects/
VITE_SENTRY_DSN=https://your-project@sentry.io/123456

# === PostHog (Analytics) ===
# Obtener en https://app.posthog.com/project/settings
VITE_POSTHOG_KEY=phc_your_project_key
VITE_POSTHOG_HOST=https://app.posthog.com

# === Rate Limiting Persistente (opcional, para producción en Vercel) ===
# Si no está configurado, se usa rate limit en memoria (inútil en serverless).
# Obtener en https://upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
