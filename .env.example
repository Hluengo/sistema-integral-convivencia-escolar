# === Servidor ===
PORT=3001
APP_URL=http://localhost:3000
NODE_ENV=development

# === Groq API (servidor / Vercel) ===
# Modelo usado: llama-3.3-70b-versatile
GROQ_API_KEY=your_groq_api_key

# === Supabase ===
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# JWT secret para verificación de tokens en API routes (server.ts / api/index.js)
# Se obtiene en Supabase Dashboard > Settings > API > JWT Settings
SUPABASE_JWT_SECRET=your_supabase_jwt_secret

# Service role key (solo para operaciones privilegiadas desde servidor)
# NO exponer en frontend. Se obtiene en Supabase Dashboard > Settings > API
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Demo local sin login (solo desarrollo). En producción dejar en false o omitir.
VITE_ALLOW_LOCAL_DEMO=false
